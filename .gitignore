# ######################################################################
# React / Vite / Create React App 官方標準 .gitignore
# ######################################################################

# 依賴套件庫（這個絕對不能推，內含幾萬個檔案）
node_modules/
/.pnp
.pnp.js

# 測試結果與覆蓋率報告
/coverage

# 製作環境的打包產出物（GitHub Pages 會用 Actions 自動編譯，不需要推本地的打包檔）
/dist
/build
/.next/
/out/

# 各類日誌檔案
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 編輯器與 IDE 設定檔（每個人電腦不同，不應共用）
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 系統快取檔案
.DS_Store
Thumbs.db

# ######################################################################
# 🔐 環境變數與機密檔案（超級重要！）
# ######################################################################
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*

*.env